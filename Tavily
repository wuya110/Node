python3 -c '
import json
path = "/root/.openclaw/openclaw.json"
# 填入你自己的 Key
MY_KEY = "<YOUR_TAVILY_API_KEY>"

with open(path, "r") as f:
    try:
        data = json.load(f)
    except:
        data = {}

if "env" not in data:
    data["env"] = {}

data["env"]["TAVILY_API_KEY"] = MY_KEY

with open(path, "w") as f:
    json.dump(data, f, indent=2)
print("\n--- ✅ 配置已更新至 openclaw.json ---")
'
